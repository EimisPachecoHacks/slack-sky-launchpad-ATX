# Anthropic API Configuration
ANTHROPIC_API_KEY=sk-ant-api03-your-api-key-here
ANTHROPIC_MODEL=claude-opus-4-6

# Gemini / Sky Launchpad self-improvement loop
# Powers the Antigravity managed repair agent, skill embeddings, and Gemini Live narration.
GEMINI_API_KEY=your-gemini-api-key-here
ANTIGRAVITY_MODEL=antigravity-preview-05-2026
GEMINI_LIVE_MODEL=gemini-3.5-live-preview

# API Configuration
API_ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Security Configuration
API_KEY_HEADER=X-API-Key
API_KEYS=your-api-key-1,your-api-key-2
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.png,.jpg,.jpeg,.pdf

# Storage Configuration
STORAGE_BACKEND=local
STORAGE_PATH=./uploads

# Logging
LOG_LEVEL=INFO
