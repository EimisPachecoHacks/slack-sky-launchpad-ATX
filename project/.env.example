# MiniMax — cloud architecture JSON generation (replaces Anthropic)
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_MODEL=MiniMax-M2
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Google Gemini — image analysis + real-time voice + self-improvement loop
# Powers diagram analysis, the Antigravity managed repair agent, skill embeddings,
# Gemini Live narration, and voice transcription.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_VISION_MODEL=gemini-3.1-pro-preview
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_TRANSCRIBE_MODEL=gemini-3.1-flash-lite
ANTIGRAVITY_MODEL=antigravity-preview-05-2026

# Anthropic (legacy/optional — no longer used by default)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# API Configuration
API_ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Security Configuration
API_KEY_HEADER=X-API-Key
API_KEYS=your-api-key-1,your-api-key-2
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.png,.jpg,.jpeg,.pdf

# Storage Configuration
STORAGE_BACKEND=local
STORAGE_PATH=./uploads

# Logging
LOG_LEVEL=INFO
