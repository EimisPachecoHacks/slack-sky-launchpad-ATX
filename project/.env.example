# Inference — Gemma 4 on the AMD MI300X, served by Ollama (OpenAI wire format).
#
#   On the hackathon pod:  bash scripts/pod_up.sh
#   On a Docker droplet:   docker compose -f docker/docker-compose.amd.yml up
#
# Leave LLM_MODEL / LLM_VISION_MODEL / LLM_BASE_URL blank to take the AMD defaults
# (gemma4:31b @ localhost:11434). Inside docker compose use the service hostname
# (http://ollama:11434/v1). Ollama needs no API key.
LLM_PROVIDER=amd
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_VISION_MODEL=

# Speech-to-text — our own Whisper on the same GPU (services/whisper_server.py),
# on its own port, hence a separate base URL.
LLM_AUDIO_BASE_URL=http://localhost:8100/v1
LLM_TRANSCRIBE_MODEL=openai/whisper-large-v3

# Skill-retrieval embeddings — served on the AMD GPU, never by a hosted provider.
# Vectors from different models are not comparable, so exactly ONE model owns the
# Atlas index. When this endpoint is unreachable, retrieval degrades to lexical
# cosine rather than writing a foreign vector.
#
# EMBED_DIMENSIONS must match the Atlas index's numDimensions (mxbai-embed-large
# is natively 1024-d). If you change EMBED_MODEL, recreate the Atlas index and
# re-run: python3 scripts/migrate_vector_index.py
#
# EMBED_SEND_DIMENSIONS: a `dimensions` request field is only honoured by Matryoshka
# models behind a serving layer that forwards it. bge-large rejects it (422); Ollama
# ignores it. Leave false — our models emit their native 1024-d.
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_API_KEY=
EMBED_MODEL=mxbai-embed-large
EMBED_DIMENSIONS=1024
EMBED_SEND_DIMENSIONS=false

# MongoDB Atlas — source of truth for skills, apps, test runs, test cases
# Without MONGODB_URI the app uses a local JSON fallback (~/.skyrchitect/db/).
MONGODB_URI=
MONGODB_DB=sky_launchpad
# Optional: name of an Atlas Vector Search index on the `skills` collection (enables $vectorSearch)
MONGODB_VECTOR_INDEX=

# Pydantic Logfire — observability/tracing (Self-Improvement Stack)
# Optional: without a token the app still instruments locally (no cloud upload).
# Get a token at https://logfire.pydantic.dev to view traces in the Logfire UI.
LOGFIRE_TOKEN=

# API Configuration
API_ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Security Configuration
API_KEY_HEADER=X-API-Key
API_KEYS=your-api-key-1,your-api-key-2
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.png,.jpg,.jpeg,.pdf

# Storage Configuration
STORAGE_BACKEND=local
STORAGE_PATH=./uploads

# Logging
LOG_LEVEL=INFO
