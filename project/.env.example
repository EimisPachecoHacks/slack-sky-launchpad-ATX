# Inference — Qwen models on Qwen Cloud (Alibaba Cloud Model Studio), via the
# OpenAI-compatible endpoint. Get a key at home.qwencloud.com/api-keys.
#
# IMPORTANT: the key prefix must match the base URL —
#   pay-as-you-go keys (sk-...)    -> https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   Token-Plan keys  (sk-sp-...)   -> https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
# Mixing them returns 401 InvalidApiKey. Leave LLM_BASE_URL blank for the
# pay-as-you-go default; set it explicitly for a Token-Plan key.
#
# Leave LLM_MODEL / LLM_VISION_MODEL blank to take the defaults
# (qwen3.7-max / qwen3.7-plus).
DASHSCOPE_API_KEY=sk-your-qwen-cloud-key-here
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_VISION_MODEL=

# Speech-to-text — Qwen-ASR on the same Qwen Cloud endpoint. Leave the base URL
# blank to reuse LLM_BASE_URL.
LLM_AUDIO_BASE_URL=
LLM_TRANSCRIBE_MODEL=qwen3-asr-flash

# Skill-retrieval embeddings — text-embedding-v4 on Qwen Cloud. Vectors from
# different models are not comparable, so exactly ONE model owns the Atlas index.
# When the endpoint is unreachable, retrieval degrades to lexical cosine rather
# than writing a foreign vector.
#
# EMBED_DIMENSIONS must match the Atlas index's numDimensions. text-embedding-v4
# is Matryoshka and honours a `dimensions` request, so EMBED_SEND_DIMENSIONS=true
# pins it to 1024. If you change EMBED_MODEL/dims, recreate the Atlas index and
# re-run: python3 scripts/migrate_vector_index.py
EMBED_BASE_URL=
EMBED_API_KEY=
EMBED_MODEL=text-embedding-v4
EMBED_DIMENSIONS=1024
EMBED_SEND_DIMENSIONS=true

# MongoDB Atlas — source of truth for skills, apps, test runs, test cases
# Without MONGODB_URI the app uses a local JSON fallback (~/.skyrchitect/db/).
MONGODB_URI=
MONGODB_DB=sky_launchpad
# Optional: name of an Atlas Vector Search index on the `skills` collection (enables $vectorSearch)
MONGODB_VECTOR_INDEX=

# Pydantic Logfire — observability/tracing (Self-Improvement Stack)
# Optional: without a token the app still instruments locally (no cloud upload).
# Get a token at https://logfire.pydantic.dev to view traces in the Logfire UI.
LOGFIRE_TOKEN=

# API Configuration
API_ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Security Configuration
API_KEY_HEADER=X-API-Key
API_KEYS=your-api-key-1,your-api-key-2
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.png,.jpg,.jpeg,.pdf

# Storage Configuration
STORAGE_BACKEND=local
STORAGE_PATH=./uploads

# Logging
LOG_LEVEL=INFO
