# Slack app credentials — create the app from manifest.json at https://api.slack.com/apps
# Bot User OAuth Token (OAuth & Permissions page, after installing to workspace)
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token with connections:write scope (Basic Information → App-Level Tokens)
SLACK_APP_TOKEN=xapp-...

# Sky Launchpad backend the Slack app talks to (NVIDIA backend in nvidia/, port 8020)
SKY_API_URL=http://localhost:8020
# Must match one of API_KEYS in the backend .env — required for /api/deploy and /api/credentials/*
# (leave empty when the backend runs in development mode with empty API_KEYS)
SKY_API_KEY=

# Optional
PORT=3002

# NVIDIA NIM API key (build.nvidia.com → Settings → API Keys) — optional fallback inference
NVIDIA_API_KEY=nvapi-...
# Hugging Face read token (for downloading Nemotron weights to the vLLM box)
HF_TOKEN=hf_...
